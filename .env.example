# 复制为 .env 后填写。勿将 .env 提交到 Git。
#
# —— 推荐：阿里云百炼（DashScope，OpenAI 兼容 Chat）——
# 控制台：https://bailian.console.aliyun.com/  → API-KEY；模型名见文档（默认 qwen-turbo，亦可用 qwen-plus、qwen3.6-plus 等）。

AI_PROVIDER=bailian
DASHSCOPE_API_KEY=
# 可选：北京默认；新加坡等国际区见阿里云文档
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=qwen-turbo
# 与官方文档一致时也可用 BAILIAN_API_KEY / BAILIAN_MODEL / BAILIAN_BASE_URL（与上列等价）

# —— 火山方舟（豆包等，OpenAI 兼容）——
# AI_PROVIDER=ark
# ARK_API_KEY=
# ARK_ENDPOINT_ID=
# ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# —— 其它提供方（择一）——
# AI_PROVIDER=gemini
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash-lite

# AI_PROVIDER=openai
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.groq.com/openai/v1
# OPENAI_MODEL=llama-3.3-70b-versatile

# 可选：前端代理校验，与 config.js 里 proxySecret 一致
# AI_PROXY_SECRET=
